{
  "name": "Abyssal-Hacker",
  "type": "dark",
  "colors": {
    "editor.background": "#0B0C16",
    "editor.foreground": "#ddf7ff",
    "editorCursor.foreground": "#82FB9C",
    "editorCursor.background": "#0B0C16",

    "editor.selectionBackground": "#1a1c2e",
    "editor.selectionForeground": "#ddf7ff",
    "editor.inactiveSelectionBackground": "#2a2d45",

    "editor.lineHighlightBackground": "#1a1c2e",
    "editorLineNumber.foreground": "#6a6e95",
    "editorLineNumber.activeForeground": "#ddf7ff",

    "editorIndentGuide.background": "#1a1c2e",
    "editorIndentGuide.activeBackground": "#2a2d45",

    "editorWhitespace.foreground": "#2a2d45",

    "editorBracketMatch.background": "#1a1c2e",
    "editorBracketMatch.border": "#82FB9C",

    "sideBar.background": "#0B0C16",
    "sideBar.foreground": "#ddf7ff",
    "sideBarSectionHeader.background": "#1a1c2e",
    "sideBarSectionHeader.foreground": "#c4d2ed",

    "activityBar.background": "#0B0C16",
    "activityBar.foreground": "#ddf7ff",
    "activityBar.inactiveForeground": "#6a6e95",

    "tab.activeBackground": "#0B0C16",
    "tab.activeForeground": "#ddf7ff",
    "tab.inactiveBackground": "#1a1c2e",
    "tab.inactiveForeground": "#c4d2ed",
    "tab.border": "#0B0C16",

    "statusBar.background": "#1a1c2e",
    "statusBar.foreground": "#ddf7ff",
    "statusBar.noFolderBackground": "#1a1c2e",

    "titleBar.activeBackground": "#1a1c2e",
    "titleBar.activeForeground": "#ddf7ff",
    "titleBar.inactiveBackground": "#0B0C16",
    "titleBar.inactiveForeground": "#c4d2ed",

    "panel.background": "#0B0C16",
    "panel.border": "#1a1c2e",

    "terminal.background": "#0B0C16",
    "terminal.foreground": "#ddf7ff",
    "terminalCursor.foreground": "#82FB9C",

    "terminal.ansiBlack": "#0B0C16",
    "terminal.ansiRed": "#50f872",
    "terminal.ansiGreen": "#4fe88f",
    "terminal.ansiYellow": "#50f7d4",
    "terminal.ansiBlue": "#829dd4",
    "terminal.ansiMagenta": "#86a7df",
    "terminal.ansiCyan": "#7cf8f7",
    "terminal.ansiWhite": "#ddf7ff",

    "terminal.ansiBrightBlack": "#6a6e95",
    "terminal.ansiBrightRed": "#50f872",
    "terminal.ansiBrightGreen": "#4fe88f",
    "terminal.ansiBrightYellow": "#50f7d4",
    "terminal.ansiBrightBlue": "#829dd4",
    "terminal.ansiBrightMagenta": "#86a7df",
    "terminal.ansiBrightCyan": "#7cf8f7",
    "terminal.ansiBrightWhite": "#ddf7ff",

    "textLink.foreground": "#82FB9C",
    "focusBorder": "#82FB9C"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6a6e95"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#4fe88f"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#86a7df"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#50f7d4"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#ddf7ff"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#7cf8f7"
      }
    }
  ]
}
