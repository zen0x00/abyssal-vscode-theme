  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#565f89"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ad8ee6"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#a9b1d6"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#449dab"
      }
    }
  ]
