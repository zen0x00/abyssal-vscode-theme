    "sideBarSectionHeader.background": "#201b17",
    "sideBarSectionHeader.foreground": "#b7aea4",

    "activityBar.background": "#14110f",
    "activityBar.foreground": "#e6dfd6",
    "activityBar.inactiveForeground": "#8f867c",

    "tab.activeBackground": "#14110f",
