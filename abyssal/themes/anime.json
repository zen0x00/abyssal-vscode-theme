  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#8f867c"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a3b18a"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#e6b566"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#e6dfd6"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#7daea3"
      }
    }
  ]
