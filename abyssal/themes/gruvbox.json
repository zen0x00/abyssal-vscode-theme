    "sideBarSectionHeader.background": "#3c3836",
    "sideBarSectionHeader.foreground": "#bdae93",

    "activityBar.background": "#282828",
    "activityBar.foreground": "#d4be98",
    "activityBar.inactiveForeground": "#a89984",

    "tab.activeBackground": "#282828",
