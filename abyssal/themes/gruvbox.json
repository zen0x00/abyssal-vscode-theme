  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#a89984"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a9b665"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#d3869b"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#d8a657"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#d4be98"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#7daea3"
      }
    }
  ]
