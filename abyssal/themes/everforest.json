  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#a6a391"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a7c080"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#d699b6"
      }
    },
    {
      "scope": "number",
      "settings": {
        "foreground": "#dbbc7f"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#d3c6aa"
      }
    },
    {
      "scope": "function",
      "settings": {
        "foreground": "#7fbbb3"
      }
    }
